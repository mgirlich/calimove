{
  "name": "calimove",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "oxfmt",
    "fix": "oxfmt && oxlint src --fix",
    "lint:eslint": "eslint src",
    "lint:oxlint": "oxlint src --type-aware",
    "lint": "pnpm lint:eslint && pnpm lint:oxlint",
    "test": "vitest run --passWithNoTests",
    "typecheck": "vue-tsc -p ./tsconfig.app.json",
    "db:types": "npx supabase gen types typescript --linked > src/types/database.generated.ts",
    "db:extract": "bash scripts/extract.sh",
    "db:seed": "node --env-file=.env.local scripts/seed.mjs",
    "data:generate": "node --env-file=.env.local scripts/generate-data.mjs",
    "icons:generate": "node scripts/generate-icons.mjs",
    "upload:audio": "node --env-file=.env.local --experimental-strip-types scripts/upload-audio.ts",
    "verify": "pnpm format && pnpm run lint && pnpm typecheck && pnpm test",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@nuxt/ui": "4.7.1",
    "@supabase/supabase-js": "2.105.1",
    "tailwindcss": "4.2.4",
    "vue": "3.5.33",
    "vue-router": "5.0.6"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@vitejs/plugin-vue": "6.0.6",
    "@vue/test-utils": "2.4.10",
    "eslint": "10.2.1",
    "eslint-plugin-oxlint": "1.62.0",
    "eslint-plugin-vue": "10.9.0",
    "jsdom": "29.1.1",
    "lint-staged": "16.4.0",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "oxlint-tsgolint": "0.22.1",
    "sharp": "0.34.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "vite": "8.0.10",
    "vite-plugin-pwa": "1.2.0",
    "vitest": "4.1.5",
    "vue-tsc": "3.2.7"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,vue}": [
      "oxlint --type-aware --fix",
      "oxfmt --write --no-error-on-unmatched-pattern"
    ]
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
