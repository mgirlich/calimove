{
  "name": "calimove",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "oxfmt",
    "fix": "oxfmt && oxlint src --fix",
    "lint:eslint": "eslint src",
    "lint:oxlint": "oxlint src --type-aware",
    "lint": "pnpm lint:eslint && pnpm lint:oxlint",
    "test": "vitest run --passWithNoTests",
    "typecheck": "vue-tsc -p ./tsconfig.app.json",
    "db:types": "npx supabase gen types typescript --linked > src/types/database.generated.ts",
    "db:extract": "bash scripts/extract.sh",
    "db:seed": "node --env-file=.env.local scripts/seed.mjs",
    "data:generate": "node --env-file=.env.local scripts/generate-data.mjs",
    "icons:generate": "node scripts/generate-icons.mjs",
    "upload:audio": "node --env-file=.env.local --experimental-strip-types scripts/upload-audio.ts",
    "verify": "pnpm format && pnpm run lint && pnpm typecheck && pnpm test",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@nuxt/ui": "4.6.1",
    "@supabase/supabase-js": "2.103.0",
    "tailwindcss": "4.2.2",
    "vue": "3.5.32",
    "vue-router": "5.0.4"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@vitejs/plugin-vue": "6.0.6",
    "@vue/test-utils": "2.4.6",
    "eslint": "10.2.0",
    "eslint-plugin-oxlint": "1.59.0",
    "eslint-plugin-vue": "10.8.0",
    "jsdom": "29.0.2",
    "lint-staged": "16.4.0",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0",
    "sharp": "0.34.5",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "vite": "8.0.8",
    "vite-plugin-pwa": "1.2.0",
    "vitest": "4.1.4",
    "vue-tsc": "3.2.6"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,vue}": [
      "oxlint --type-aware --fix",
      "oxfmt --write --no-error-on-unmatched-pattern"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
