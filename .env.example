# Copy this file to .env.local and fill in the values.
# .env.local is gitignored.

# Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://your-project.supabase.co

# Service role key — bypasses RLS; only used for seeding (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Your Supabase user UUID — needed to migrate existing workout history
# Find it in: Supabase dashboard → Authentication → Users
# Leave unset to skip execution migration.
OWNER_USER_ID=your-user-uuid
